            },
            "url": { "raw": "{{baseUrl}}/v1/jobs", "host": ["{{baseUrl}}"], "path": ["v1", "jobs"] }
          }
        },
        {
          "name": "GET /v1/jobs/{id} — poll until SUCCEEDED (after promotion)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const attempts = (pm.collectionVariables.get('schedPollAttempts') || 0) + 1;",
                  "pm.collectionVariables.set('schedPollAttempts', attempts);",
                  "if (j.status !== 'SUCCEEDED' && attempts < 20) {",
                  "  setTimeout(() => postman.setNextRequest('GET /v1/jobs/{id} — poll until SUCCEEDED (after promotion)'), 500);",
                  "} else {",
                  "  pm.test('eventually SUCCEEDED', () => pm.expect(j.status).to.eql('SUCCEEDED'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/jobs/{{schedJobId}}", "host": ["{{baseUrl}}"], "path": ["v1", "jobs", "{{schedJobId}}"] }
          }
        }
      ]
    },
    {
      "name": "7 · Queue stats",
      "item": [
        {
          "name": "GET /v1/queues/{queue}/stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/queues/{{queue}}/stats", "host": ["{{baseUrl}}"], "path": ["v1", "queues", "{{queue}}", "stats"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "['ready','tenant_ready','tenant_scheduled','tenant_leased','tenant_succeeded','tenant_failed','tenant_dead','tenant_pending'].forEach(k => {",
