                  "  const body = m === 'fail' ? { queue, type: 'echo', payload, maxAttempts: 1 } : { queue, type: 'echo', payload, maxAttempts: 4 };",
                  "  pm.sendRequest({",
                  "    url: `${baseUrl}/v1/jobs`,",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json', 'X-API-Key': apiKey },",
                  "    body: { mode: 'raw', raw: JSON.stringify(body) }",
                  "  }, (err, res) => {",
                  "    done++;",
                  "    if (!err && res && res.code === 202) ok++; else fail++;",
                  "    if (done === N) {",
                  "      pm.collectionVariables.set('mixedOk', ok);",
                  "      pm.collectionVariables.set('mixedFail', fail);",
                  "    }",
                  "  });",
                  "}"
                ]
              }
