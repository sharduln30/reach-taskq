{
  "info": {
    "name": "Reach TaskQ",
    "_postman_id": "reach-taskq-2026-04-30",
    "description": "Multi-tenant job queue — full API coverage + functional tests + resilience / durability bombard suite.\n\n**Run as:**\n- Postman GUI → import this + the env, run folders top-to-bottom.\n- CLI:\n  - `newman run postman/reach-taskq.postman_collection.json -e postman/reach-taskq.postman_environment.json --folder 'Smoke'`\n  - `./postman/run-bombard.sh` for parallel durability run.\n\n**Folders** (run order matters for the smoke flow):\n1. Health\n2. Tenant\n3. Jobs · Happy path\n4. Jobs · Idempotency\n5. Jobs · Retry & DLQ\n6. Jobs · Scheduled\n7. Queue stats\n8. Resilience · Bombard (durability)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "apiKey", "value": "demo-api-key-do-not-use-in-prod" },
    { "key": "queue", "value": "default" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Helpers shared across requests.",
          "pm.collectionVariables.set('runId', pm.collectionVariables.get('runId') || `${Date.now()}-${Math.random().toString(36).slice(2,8)}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global timing / no-5xx assertions on every request.",
          "pm.test('Response time under 2s', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
          "pm.test('Not a 5xx server error', () => pm.expect(pm.response.code).to.be.below(500));"
        ]
      }
    }
  ],
  "item": [
    {
