    {
      "name": "3 · Jobs · Happy path",
      "item": [
        {
          "name": "POST /v1/jobs (success)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('happyNote', `${pm.collectionVariables.get('runId')}-happy-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted', () => pm.response.to.have.status(202));",
                  "const j = pm.response.json();",
                  "pm.test('has uuid id', () => pm.expect(j.id).to.match(/^[0-9a-f-]{36}$/i));",
                  "pm.test('status READY|SCHEDULED', () => pm.expect(['READY', 'SCHEDULED']).to.include(j.status));",
                  "pm.test('idempotentReplay=false', () => pm.expect(j.idempotentReplay).to.be.false);",
                  "pm.test('Location header present', () => pm.expect(pm.response.headers.get('Location')).to.include('/v1/jobs/'));",
                  "pm.collectionVariables.set('lastJobId', j.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"type\": \"echo\",\n  \"payload\": { \"outcome\": \"success\", \"note\": \"{{happyNote}}\" },\n  \"priority\": 50,\n  \"maxAttempts\": 5\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/jobs", "host": ["{{baseUrl}}"], "path": ["v1", "jobs"] }
          }
        },
        {
          "name": "GET /v1/jobs/{id} — poll until SUCCEEDED",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches', () => pm.expect(j.id).to.eql(pm.collectionVariables.get('lastJobId')));",
                  "pm.test('reachable terminal state', () => pm.expect(['READY','LEASED','SUCCEEDED']).to.include(j.status));",
                  "// Poll loop: re-run this request up to 10 times until SUCCEEDED.",
                  "const attempts = (pm.collectionVariables.get('happyPollAttempts') || 0) + 1;",
                  "pm.collectionVariables.set('happyPollAttempts', attempts);",
                  "if (j.status !== 'SUCCEEDED' && attempts < 10) {",
                  "  setTimeout(() => postman.setNextRequest('GET /v1/jobs/{id} — poll until SUCCEEDED'), 300);",
                  "} else {",
                  "  pm.test('terminal=SUCCEEDED', () => pm.expect(j.status).to.eql('SUCCEEDED'));",
                  "  pm.test('attempt=0 (no retries)', () => pm.expect(j.attempt).to.eql(0));",
                  "  pm.collectionVariables.set('happyPollAttempts', 0);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/jobs/{{lastJobId}}", "host": ["{{baseUrl}}"], "path": ["v1", "jobs", "{{lastJobId}}"] }
          }
        },
        {
          "name": "GET /v1/jobs?status=SUCCEEDED&limit=5",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/jobs?status=SUCCEEDED&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "jobs"],
              "query": [
                { "key": "status", "value": "SUCCEEDED" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('items array', () => pm.expect(j.items).to.be.an('array'));",
                  "pm.test('limit echoed', () => pm.expect(j.limit).to.eql(5));",
                  "pm.test('items <= limit', () => pm.expect(j.items.length).to.be.at.most(5));",
                  "if (j.items.length) {",
                  "  pm.test('items have all-SUCCEEDED', () => j.items.forEach(i => pm.expect(i.status).to.eql('SUCCEEDED')));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4 · Jobs · Idempotency",
      "item": [
        {
          "name": "POST /v1/jobs with key (first → 202)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('idempKey', `key-${pm.collectionVariables.get('runId')}-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted (new submit)', () => pm.response.to.have.status(202));",
                  "const j = pm.response.json();",
                  "pm.test('idempotentReplay=false', () => pm.expect(j.idempotentReplay).to.be.false);",
                  "pm.collectionVariables.set('idempJobId', j.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"type\": \"echo\",\n  \"payload\": { \"outcome\": \"success\", \"k\": \"{{idempKey}}\" }\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/jobs", "host": ["{{baseUrl}}"], "path": ["v1", "jobs"] }
          }
        },
        {
          "name": "POST /v1/jobs with same key + same payload (replay → 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK (idempotent replay)', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('idempotentReplay=true', () => pm.expect(j.idempotentReplay).to.be.true);",
                  "pm.test('id matches first submit', () => pm.expect(j.id).to.eql(pm.collectionVariables.get('idempJobId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"type\": \"echo\",\n  \"payload\": { \"outcome\": \"success\", \"k\": \"{{idempKey}}\" }\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/jobs", "host": ["{{baseUrl}}"], "path": ["v1", "jobs"] }
          }
        },
        {
          "name": "POST /v1/jobs with same key + DIFFERENT payload (mismatch → 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('409 Conflict', () => pm.response.to.have.status(409));",
                  "const j = pm.response.json();",
                  "pm.test('error code idempotency_conflict', () => pm.expect(j.code || j.error || '').to.match(/idempot/i));",
                  "pm.test('points at original job', () => {",
                  "  const ref = JSON.stringify(j);",
                  "  pm.expect(ref).to.include(pm.collectionVariables.get('idempJobId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"type\": \"echo\",\n  \"payload\": { \"outcome\": \"fail\", \"k\": \"{{idempKey}}\" }\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/jobs", "host": ["{{baseUrl}}"], "path": ["v1", "jobs"] }
          }
        }
      ]
    },
    {
      "name": "5 · Jobs · Retry & DLQ",
      "item": [
        {
          "name": "POST /v1/jobs (terminal fail, maxAttempts=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted', () => pm.response.to.have.status(202));",
                  "pm.collectionVariables.set('failJobId', pm.response.json().id);",
                  "pm.collectionVariables.set('dlqPollAttempts', 0);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"type\": \"echo\",\n  \"payload\": { \"outcome\": \"fail\" },\n  \"maxAttempts\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/jobs", "host": ["{{baseUrl}}"], "path": ["v1", "jobs"] }
          }
        },
        {
          "name": "GET /v1/jobs/{id} — poll until DEAD",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const attempts = (pm.collectionVariables.get('dlqPollAttempts') || 0) + 1;",
                  "pm.collectionVariables.set('dlqPollAttempts', attempts);",
                  "if (j.status !== 'DEAD' && attempts < 30) {",
                  "  setTimeout(() => postman.setNextRequest('GET /v1/jobs/{id} — poll until DEAD'), 500);",
                  "} else {",
                  "  pm.test('terminal=DEAD', () => pm.expect(j.status).to.eql('DEAD'));",
                  "  // outcome=fail is non-retryable so the worker markDead's at attempt=0;",
                  "  // for a flap-then-fail job attempt would equal maxAttempts. Allow either.",
                  "  pm.test('attempt within budget', () => pm.expect(j.attempt).to.be.at.most(j.maxAttempts));",
                  "  pm.test('lastError populated', () => pm.expect(j.lastError).to.be.a('string').and.not.empty);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/jobs/{{failJobId}}", "host": ["{{baseUrl}}"], "path": ["v1", "jobs", "{{failJobId}}"] }
          }
        },
        {
          "name": "GET /v1/dlq — assert dead job present",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('items array', () => pm.expect(j.items).to.be.an('array'));",
                  "const id = pm.collectionVariables.get('failJobId');",
                  "const found = j.items.find(i => i.id === id);",
                  "pm.test('failed job is in DLQ', () => pm.expect(found, `did not find ${id}`).to.exist);",
                  "if (found) pm.test('DLQ entry status=DEAD', () => pm.expect(found.status).to.eql('DEAD'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/dlq?limit=200",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "dlq"],
              "query": [{ "key": "limit", "value": "200" }]
            }
          }
        },
        {
          "name": "POST /v1/dlq/{id}/replay",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches', () => pm.expect(j.id).to.eql(pm.collectionVariables.get('failJobId')));",
                  "pm.test('not DEAD anymore', () => pm.expect(['READY','SCHEDULED','LEASED','SUCCEEDED','FAILED','DEAD']).to.include(j.status));",
                  "pm.test('cleared lastError or fresh attempt', () => pm.expect(j.attempt).to.be.at.most(j.maxAttempts));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/dlq/{{failJobId}}/replay", "host": ["{{baseUrl}}"], "path": ["v1", "dlq", "{{failJobId}}", "replay"] }
          }
        }
      ]
    },
