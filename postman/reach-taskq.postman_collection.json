    },
    {
      "name": "8 · Resilience · Bombard",
      "description": "Durability / resilience suite. Designed to be run with Newman + iterations to generate real load.\n\n**Scenarios:**\n- **Burst submit (in-script)** — fires 50 submits in pre-request via `pm.sendRequest`, asserts all 2xx and counts 4xx/5xx.\n- **Concurrent idempotent submits** — same key fired N times; assert exactly one 202 and the rest are 200 with the same id.\n- **DLQ flood** — submits a wave of fail jobs to fill DLQ.\n- **Mixed-outcome flood** — random success/flap/fail.\n- **Stats sanity after flood** — confirms counts moved monotonically.\n\nFor real durability load use `./postman/run-bombard.sh` which runs this folder with iterations and CSV-driven payload variation.",
      "item": [
        {
          "name": "Burst submit (50 in pre-request)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Fire N submits sequentially via pm.sendRequest. Aggregate counts into vars.",
                  "const N = parseInt(pm.collectionVariables.get('burstN') || '50', 10);",
                  "const baseUrl = pm.collectionVariables.get('baseUrl') || pm.variables.get('baseUrl');",
                  "const apiKey = pm.collectionVariables.get('apiKey') || pm.variables.get('apiKey');",
                  "const queue = pm.collectionVariables.get('queue') || 'default';",
                  "let ok = 0, fail = 0, latencies = [];",
                  "let started = Date.now();",
                  "function send(i) {",
                  "  if (i >= N) {",
                  "    pm.collectionVariables.set('burstOk', ok);",
                  "    pm.collectionVariables.set('burstFail', fail);",
                  "    pm.collectionVariables.set('burstLatencies', JSON.stringify(latencies));",
                  "    pm.collectionVariables.set('burstWallMs', Date.now() - started);",
                  "    return;",
                  "  }",
                  "  const t0 = Date.now();",
                  "  pm.sendRequest({",
                  "    url: `${baseUrl}/v1/jobs`,",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json', 'X-API-Key': apiKey },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ queue, type: 'echo', payload: { outcome: 'success', i } }) }",
                  "  }, (err, res) => {",
                  "    const ms = Date.now() - t0;",
                  "    latencies.push(ms);",
                  "    if (!err && res && res.code >= 200 && res.code < 300) ok++; else fail++;",
                  "    send(i + 1);",
                  "  });",
                  "}",
                  "send(0);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// The 'request' on this item is the final stats fetch; assert burst totals here.",
                  "const ok = parseInt(pm.collectionVariables.get('burstOk') || '0', 10);",
                  "const fail = parseInt(pm.collectionVariables.get('burstFail') || '0', 10);",
                  "const N = parseInt(pm.collectionVariables.get('burstN') || '50', 10);",
                  "const lats = JSON.parse(pm.collectionVariables.get('burstLatencies') || '[]');",
                  "const wallMs = parseInt(pm.collectionVariables.get('burstWallMs') || '0', 10);",
                  "lats.sort((a,b) => a-b);",
                  "const p = (q) => lats[Math.min(lats.length - 1, Math.floor(q * lats.length))];",
                  "console.log(`burst: ok=${ok} fail=${fail} N=${N} wall=${wallMs}ms p50=${p(0.5)}ms p95=${p(0.95)}ms p99=${p(0.99)}ms`);",
                  "pm.test(`burst ok=${ok}/${N}`, () => pm.expect(ok).to.eql(N));",
                  "pm.test('burst no failures', () => pm.expect(fail).to.eql(0));",
                  "pm.test('burst p95 < 500ms', () => pm.expect(p(0.95)).to.be.below(500));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/queues/{{queue}}/stats", "host": ["{{baseUrl}}"], "path": ["v1", "queues", "{{queue}}", "stats"] }
          }
        },
        {
          "name": "Concurrent idempotent submits (same key x10)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const baseUrl = pm.variables.get('baseUrl');",
                  "const apiKey = pm.variables.get('apiKey');",
                  "const queue = pm.variables.get('queue') || 'default';",
                  "const key = `idem-${Date.now()}-${Math.random().toString(36).slice(2,8)}`;",
                  "pm.collectionVariables.set('concIdempKey', key);",
                  "const N = 10;",
                  "let new202 = 0, replay200 = 0, other = 0, ids = new Set();",
                  "let done = 0;",
                  "for (let i = 0; i < N; i++) {",
                  "  pm.sendRequest({",
                  "    url: `${baseUrl}/v1/jobs`,",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json', 'X-API-Key': apiKey, 'Idempotency-Key': key },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ queue, type: 'echo', payload: { outcome: 'success', k: key } }) }",
                  "  }, (err, res) => {",
                  "    done++;",
                  "    if (err || !res) { other++; }",
                  "    else if (res.code === 202) { new202++; try { ids.add(res.json().id); } catch(_){} }",
                  "    else if (res.code === 200) { replay200++; try { ids.add(res.json().id); } catch(_){} }",
                  "    else { other++; }",
                  "    if (done === N) {",
                  "      pm.collectionVariables.set('concNew202', new202);",
                  "      pm.collectionVariables.set('concReplay200', replay200);",
                  "      pm.collectionVariables.set('concOther', other);",
                  "      pm.collectionVariables.set('concIds', JSON.stringify([...ids]));",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const new202 = parseInt(pm.collectionVariables.get('concNew202') || '0', 10);",
                  "const replay200 = parseInt(pm.collectionVariables.get('concReplay200') || '0', 10);",
                  "const other = parseInt(pm.collectionVariables.get('concOther') || '0', 10);",
                  "const ids = JSON.parse(pm.collectionVariables.get('concIds') || '[]');",
                  "console.log(`idempotent burst: new202=${new202} replay200=${replay200} other=${other} uniqIds=${ids.length}`);",
                  "pm.test('exactly one new submit (202)', () => pm.expect(new202).to.eql(1));",
                  "pm.test('rest are idempotent replays (200)', () => pm.expect(replay200).to.eql(9));",
                  "pm.test('no errors', () => pm.expect(other).to.eql(0));",
                  "pm.test('all responses point at one job id', () => pm.expect(ids.length).to.eql(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/queues/{{queue}}/stats", "host": ["{{baseUrl}}"], "path": ["v1", "queues", "{{queue}}", "stats"] }
          }
        },
